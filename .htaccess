# ================================================================
#  AUTO pièces service — .htaccess
#  - Masque les extensions .html dans les URLs
#  - Redirige les anciennes URLs .html en 301 (SEO)
#  - Désactive le listage des dossiers
#  - Protège les fichiers sensibles
#  - Désactive le cache serveur LiteSpeed (évite le contenu obsolète après déploiement)
# ================================================================

Options -Indexes

# ── Désactiver le cache LiteSpeed pour ce site (toujours servir le fichier réel) ──
<IfModule LiteSpeed>
  CacheDisable public /
</IfModule>

# ── Forcer la revalidation du cache navigateur sur HTML/CSS/JS ──
<IfModule mod_headers.c>
  <FilesMatch "\.(html|css|js)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

RewriteEngine On

# ── Forcer HTTPS (activer une fois le SSL actif sur Hostinger) ──
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# ── Rediriger /page.html → /page (301 permanent, bon pour le SEO) ──
RewriteCond %{THE_REQUEST} \s/+(.*?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# ── Servir les fichiers réels (CSS, JS, images, PHP) directement ──
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ── Réécriture interne : /apropos → apropos.html (sans redirection) ──
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^/]+)/?$ $1.html [L]

# ── Bloquer l'accès direct au dossier api/ depuis le navigateur ──
<FilesMatch "^devis\.php$">
  <If "%{HTTP:X-Requested-With} != 'XMLHttpRequest' && %{REQUEST_METHOD} != 'POST'">
    Order Deny,Allow
    Deny from all
  </If>
</FilesMatch>

# ── Page d'erreur 404 personnalisée (optionnel) ──
# ErrorDocument 404 /404.html
